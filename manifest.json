{
  "manifest_version": 3,
  "name": "MeetVocab — Live English Helper",
  "version": "1.0.0",
  "description": "Click words in Google Meet captions for English definitions, save vocabulary, and review flashcards. 100% local, free, no API keys.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://api.dictionaryapi.dev/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MeetVocab Dashboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["lib/store.js", "lib/i18n.js", "lib/dictionary.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
